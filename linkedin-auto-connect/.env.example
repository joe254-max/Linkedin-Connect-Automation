# ============================================
# LinkedIn Auto-Connect Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# Your LinkedIn login credentials
LINKEDIN_EMAIL=your-email@example.com
LINKEDIN_PASSWORD=your-password-here

# Daily connection request limit (default: 20, max recommended: 20)
DAILY_LIMIT=20

# Send a personalized message with each connection request?
# Set to "true" to include a note, "false" to send without a note
SEND_MESSAGE=false

# Custom connection message (use {firstName} as a placeholder for the person's name)
CONNECTION_MESSAGE=Hi {firstName}, I'd love to connect and grow our networks together!
